<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/scss/main.css" />
    <title>{{title}}</title>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/">🐦 Flappy Bird</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
          aria-controls="navbarNav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link" href="/about">Sobre</a></li>
            {{#if user.isLoggedIn}}
              <li class="nav-item"><a class="nav-link" href="/">Jogar</a></li>
              <li class="nav-item"><a class="nav-link" href="/ranking">Ranking</a></li>
              <li class="nav-item">
                <span class="nav-link disabled">Olá, {{user.name}}</span>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/logout">Sair</a>
              </li>
            {{else}}
              <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
              <li class="nav-item"><a class="nav-link" href="/register">Criar Conta</a></li>
            {{/if}}
          </ul>
        </div>
      </div>
    </nav>

    <div class="page-header">
      <div class="container">
        <h1>{{headerTitle}}</h1>
      </div>
    </div>

    <main class="container pb-5">
      {{{body}}}
    </main>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
